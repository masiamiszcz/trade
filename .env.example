# Environment Configuration
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file with sensitive data!

# ===========================
# DATABASE CONFIGURATION
# ===========================
DB_PASSWORD=YourStrong!Passw0rd
DB_USER=sa
DB_SERVER=sqlserver
DB_NAME=TradingDB

# ===========================
# JWT & AUTHENTICATION
# ===========================
JWT_KEY=ThisIsAVerySecureSecretKeyForJwtTokenGenerationMinimum32Characters!
JWT_ISSUER=TradingPlatform
JWT_AUDIENCE=TradingPlatformUsers
JWT_EXPIRY_MINUTES=120

# ===========================
# WIREGUARD VPN CONFIGURATION
# ===========================

# Password for WireGuard admin panel
# Access at: http://localhost:51821
WG_ADMIN_PASSWORD=changeme123

# For production: use your actual VPS public IP
# Example: WG_HOST=192.168.1.100 or WG_HOST=api.example.com
WG_HOST=localhost

# ===========================
# NGINX CONFIGURATION
# ===========================

# Your domain name (for production SSL certificates)
NGINX_HOST=localhost

# Port for Nginx (usually 80 for HTTP, 443 for HTTPS)
NGINX_PORT=80

# ===========================
# FRONTEND CONFIGURATION
# ===========================

# API URL for frontend requests
# Development: /api (proxied through Nginx)
# Production: https://api.example.com/api
REACT_APP_API_URL=/api

# ===========================
# PRODUCTION VPS CONFIGURATION
# ===========================

# Your VPS public IP address (for WireGuard setup)
# Example: VPS_PUBLIC_IP=123.45.67.89
VPS_PUBLIC_IP=

# ===========================
# SSL/HTTPS CONFIGURATION
# ===========================

# Enable HTTPS (for production)
# Set to true and ensure ssl-certs/ directory has your certificates
ENABLE_SSL=false

# Email for Let's Encrypt certificate renewal notifications
SSL_EMAIL=admin@example.com

# ===========================
# APPLICATION ENVIRONMENT
# ===========================

# Environment type: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Development

# Log level: Debug, Information, Warning, Error
LOG_LEVEL=Information

# ===========================
# VPN SECURITY SETTINGS
# ===========================

# VPN subnet for admin access
# This is the subnet range that can access /api/admin routes
VPN_ADMIN_SUBNET=10.8.0.0/24

# Block non-VPN admin requests (true = strict security)
BLOCK_NON_VPN_ADMIN=true

# ===========================
# NOTES FOR DEPLOYMENT
# ===========================
# 
# Local Development:
# 1. Copy .env.example to .env
# 2. Modify values if needed (defaults work for localhost)
# 3. Run: docker-compose up -d
#
# Production Deployment:
# 1. Create .env on your VPS with production values
# 2. Run: docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# 3. Setup WireGuard client on your admin machine
# 4. Configure SSL certificates in ./ssl-certs/
#
# Security Best Practices:
# - Change all default passwords
# - Use strong, unique WireGuard password
# - Store .env in secure location (never commit to git)
# - Rotate keys periodically
# - Monitor /var/log/nginx/admin_access.log for suspicious activity
#
