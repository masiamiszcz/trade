@baseUrl = http://localhost
@superAdminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..OD7FPqHzr0rZmQr8BfuPwFy6piVsPcDQuSkSG6tqthY

### 1. GET - Pokaż wszystkie requesty
GET {{baseUrl}}/api/approvals HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

### 2. GET - Pokaż pending requesty
GET {{baseUrl}}/api/approvals/pending HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

### 3. CREATE - Instrument z REQUEST_CHANGE (Change Name)
POST {{baseUrl}}/api/instruments HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

{
  "name": "Test Instrument 1",
  "symbol": "TEST1",
  "description": "Test instrument for approval flow",
  "baseCurrency": "USD",
  "quoteCurrency": "EUR",
  "type": "FX",
  "pillar": "STANDARD"
}

### 4. UPDATE - Zmień nazwę (tworzy AdminRequest)
PUT {{baseUrl}}/api/instruments/replace_with_id HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

{
  "name": "Test Instrument 1 RENAMED",
  "symbol": "TEST1",
  "description": "Test instrument for approval flow - UPDATED",
  "baseCurrency": "USD",
  "quoteCurrency": "EUR",
  "type": "FX",
  "pillar": "STANDARD"
}

### 5. CREATE NEW - Tworzy AdminRequest
POST {{baseUrl}}/api/instruments HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

{
  "name": "New Instrument",
  "symbol": "NEWINST",
  "description": "Brand new instrument",
  "baseCurrency": "USD",
  "quoteCurrency": "GBP",
  "type": "FX",
  "pillar": "STANDARD"
}

### 6. BLOCK - Zablokuj instrument (tworzy AdminRequest)
PATCH {{baseUrl}}/api/instruments/replace_with_id/block HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

### 7. UNBLOCK - Odblokuj instrument (tworzy AdminRequest)
PATCH {{baseUrl}}/api/instruments/replace_with_id/unblock HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

### 8. DELETE - Usuń instrument (tworzy AdminRequest)
DELETE {{baseUrl}}/api/instruments/replace_with_id HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

### 9. APPROVE - Zatwierdź request (replace_request_id z kroku 2 lub 4)
POST {{baseUrl}}/api/approvals/replace_request_id/approve HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

### 10. REJECT - Odrzuć request
POST {{baseUrl}}/api/approvals/replace_request_id/reject HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

{
  "reason": "Nie odpowiada strategii"
}

### 11. ADD COMMENT - Dodaj komentarz do requestu
POST {{baseUrl}}/api/approvals/replace_request_id/comment HTTP/1.1
Authorization: Bearer {{superAdminToken}}
Content-Type: application/json

{
  "comment": "Czekamy na więcej informacji"
}
